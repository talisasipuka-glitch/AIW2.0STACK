.DS_Store
.env
.env.local
.env.*.local

node_modules/
dist/
build/
.next/
out/

# Deployment artifacts that contain URLs and live data
deployments/factory/build/
deployments/factory/secrets/
deployments/engine/secrets/

# Local logs
logs/*.log
logs/*.jsonl

# Apify raw dumps can grow large
research/02-niche-research/*/raw/

# Claude Code session caches
.claude/cache/
.claude/.local/

# Test and debug artifacts
test-crawl.json
test-output.json

# OS files
*.swp
*.swo
Thumbs.db

# Upstream skill dev dependency lockfiles. We never `npm/pnpm install` inside
# .claude/skills/*; Claude Code only reads the skill's .md files at runtime.
# Dependabot was scanning these and generating false-positive alerts on dev
# tooling that's not in our deployed runtime surface.
website-factory/.claude/skills/**/pnpm-lock.yaml
website-factory/.claude/skills/**/package-lock.json
website-factory/.claude/skills/**/yarn.lock
